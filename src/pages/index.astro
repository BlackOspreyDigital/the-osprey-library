---
// src/pages/index.astro
// Main landing page for Crescendo Engine
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Crescendo Engine | Custom 3D Vulkan Engine</title>
    <style>
      :root {
        --bg-color: #0d1117;
        --text-main: #c9d1d9;
        --accent: #58a6ff;
        --accent-glow: rgba(88, 166, 255, 0.15);
        --card-bg: #161b22;
        --border-color: #30363d;
      }
      
      body {
        font-family: system-ui, -apple-system, sans-serif;
        background-color: var(--bg-color);
        color: var(--text-main);
        margin: 0;
        padding: 0;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      .hero {
        text-align: center;
        padding: 8rem 2rem 6rem;
        border-bottom: 1px solid var(--border-color);
        background: radial-gradient(circle at top center, #1f2937 0%, transparent 70%);
      }

      h1 {
        font-size: 4.5rem;
        margin-bottom: 1rem;
        color: #ffffff;
        letter-spacing: -0.05em;
        text-shadow: 0 0 30px var(--accent-glow);
      }

      .subtitle {
        font-size: 1.5rem;
        color: #8b949e;
        max-width: 650px;
        margin: 0 auto 2.5rem;
      }

      .tech-stack {
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .tag {
        background-color: transparent;
        border: 1px solid var(--border-color);
        padding: 0.4rem 1.2rem;
        border-radius: 99px;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 2rem;
        padding: 5rem 2rem;
        max-width: 1200px;
        margin: 0 auto;
      }

      .card {
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 2.5rem;
        transition: transform 0.2s ease, border-color 0.2s ease;
      }

      .card:hover {
        transform: translateY(-4px);
        border-color: var(--accent);
        box-shadow: 0 10px 30px var(--accent-glow);
      }

      .card h3 {
        color: #ffffff;
        font-size: 1.3rem;
        margin-top: 0;
        margin-bottom: 1rem;
      }

      .cta-container {
        padding: 2rem 2rem 6rem;
      }
      
      .action-buttons {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
      }

      .btn {
        display: inline-block;
        background-color: var(--accent);
        color: #0d1117;
        text-decoration: none;
        padding: 1rem 2.5rem;
        border-radius: 8px;
        font-weight: bold;
        font-size: 1.1rem;
        transition: opacity 0.2s ease;
      }

      .btn:hover {
        opacity: 0.9;
      }

      /* New Status Button Styles */
      .btn-status {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        background-color: var(--card-bg);
        color: var(--text-main);
        text-decoration: none;
        padding: 1rem 2.5rem;
        border-radius: 8px;
        border: 1px solid var(--border-color);
        font-weight: bold;
        font-size: 1.1rem;
        transition: all 0.2s ease;
      }

      .btn-status:hover {
        border-color: #8b949e;
        transform: translateY(-2px);
      }

      .status-icon {
        color: #8b949e;
        transition: color 0.3s ease, filter 0.3s ease;
      }

      .btn-status.is-online .status-icon {
        color: #2ea043;
        filter: drop-shadow(0 0 8px rgba(46, 160, 67, 0.4));
      }
      
      .btn-status.is-online {
        border-color: rgba(46, 160, 67, 0.3);
      }

      .btn-status.is-offline .status-icon {
        color: #f85149;
        filter: drop-shadow(0 0 8px rgba(248, 81, 73, 0.4));
      }
      
      .btn-status.is-offline {
        border-color: rgba(248, 81, 73, 0.3);
      }
    </style>
  </head>
  <body>
    <main>
      <header class="hero">
        <h1>Crescendo Engine</h1>
        <p class="subtitle">A high-performance, custom 3D game engine engineered for bare-metal control and rendering speed.</p>
        <div class="tech-stack">
          <span class="tag">C++ Architecture</span>
          <span class="tag">Vulkan API</span>
          <span class="tag">Linux Native</span>
        </div>
      </header>

      <section class="features">
        <div class="card">
          <h3>Vulkan Rendering Pipeline</h3>
          <p>Built directly on the Vulkan API to leverage modern, low-overhead GPU commands, explicit memory management, and highly parallelized draw calls.</p>
        </div>
        <div class="card">
          <h3>C++ Core</h3>
          <p>A deterministic, memory-safe architecture written from the ground up in C++ to guarantee maximum throughput and minimal CPU latency.</p>
        </div>
        <div class="card">
          <h3>Development Log</h3>
          <p>Documenting the architecture decisions, from setting up the swapchain and writing custom shaders to exploring future voxel systems.</p>
        </div>
      </section>

      <section class="cta-container">
        <div class="action-buttons">
          <a href="/devlog" class="btn">Read the Devlog</a>
          
          <a href="/status" class="btn-status" id="home-status-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="status-icon"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5V19A9 3 0 0 0 21 19V5"></path><path d="M3 12A9 3 0 0 0 21 12"></path></svg>
            Server Status
          </a>
        </div>
      </section>
    </main>

    <script>
      async function pingInfrastructure() {
        const btn = document.getElementById('home-status-btn');
        if (!btn) return;

        try {
          const response = await fetch('https://api.theospreylibrary.com/teamspeak');
          const data = await response.json();

          if (data.status === 'online') {
            btn.classList.add('is-online');
          } else {
            btn.classList.add('is-offline');
          }
        } catch (error) {
          btn.classList.add('is-offline');
        }
      }

      pingInfrastructure();
    </script>
  </body>
</html>