---
// src/pages/status.astro
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>System Status | Crescendo Engine</title>
    <style>
      body {
        font-family: system-ui, -apple-system, sans-serif;
        background-color: #0d1117;
        color: #c9d1d9;
        margin: 0 auto;
        padding: 4rem 2rem;
        max-width: 800px;
        line-height: 1.6;
      }
      h1 { color: #ffffff; font-size: 2.5rem; margin-bottom: 0.5rem; }
      .subtitle { color: #8b949e; margin-bottom: 3rem; }
      
      .status-card {
        background-color: #161b22;
        border: 1px solid #30363d;
        border-radius: 8px;
        padding: 1.5rem;
        margin-bottom: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .server-info h2 {
        margin: 0 0 0.25rem 0;
        color: #ffffff;
        font-size: 1.2rem;
      }

      .server-info p {
        margin: 0;
        font-size: 0.85rem;
        color: #8b949e;
      }

      .indicator {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: bold;
        font-size: 0.9rem;
      }

      .dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background-color: #8b949e; 
      }
      .dot.online {
        background-color: #2ea043;
        box-shadow: 0 0 10px rgba(46, 160, 67, 0.4);
      }
      .dot.offline {
        background-color: #f85149;
        box-shadow: 0 0 10px rgba(248, 81, 73, 0.4);
      }
      
      .text-online { color: #2ea043; }
      .text-offline { color: #f85149; }
    </style>
  </head>
  <body>
    <a href="/" style="color: #58a6ff; text-decoration: none; font-weight: bold;">&larr; Back to Home</a>
    
    <h1>System Status</h1>
    <p class="subtitle">Live monitoring for the Crescendo Engine infrastructure.</p>

    <div class="status-card">
      <div class="server-info">
        <h2>TeamSpeak 5 Server</h2>
        <p>ts.theospreylibrary.com</p>
      </div>
      <div class="indicator" id="ts-status">
        <div class="dot"></div>
        <span>Checking...</span>
      </div>
    </div>

    <script>
      async function checkServerStatus() {
        const statusElement = document.getElementById('ts-status');
        if (!statusElement) return;

        try {
          const response = await fetch('https://api.theospreylibrary.com/teamspeak');
          const data = await response.json();

          if (data.status === 'online') {
            statusElement.innerHTML = '<div class="dot online"></div><span class="text-online">Operational</span>';
          } else {
            statusElement.innerHTML = '<div class="dot offline"></div><span class="text-offline">Offline</span>';
          }
        } catch (error) {
          statusElement.innerHTML = '<div class="dot offline"></div><span class="text-offline">Connection Failed</span>';
        }
      }

      checkServerStatus();
      setInterval(checkServerStatus, 60000);
    </script>
  </body>
</html>