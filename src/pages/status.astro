---
// src/pages/status.astro
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>System Status | Osprey Infrastructure</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    
    <style>
      :root {
        --bg-base: #050505;
        --bg-surface: #0a0a0a;
        --text-main: #ededed;
        --text-muted: #888888;
        --accent: #58a6ff;
        --border-color: #222222;
      }
      
      body {
        font-family: 'Inter', sans-serif;
        background-color: var(--bg-base);
        color: var(--text-main);
        margin: 0 auto;
        padding: 4rem 2rem;
        max-width: 800px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      a.back-link {
        color: var(--text-muted);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.85rem;
        transition: color 0.2s ease;
        display: inline-block;
        margin-bottom: 3rem;
        font-family: 'JetBrains Mono', monospace;
        letter-spacing: 0.05em;
      }

      a.back-link:hover {
        color: var(--text-main);
      }
      
      h1 { 
        color: #ffffff; 
        font-size: 2.5rem; 
        font-weight: 800;
        margin-bottom: 0.5rem; 
        letter-spacing: -0.04em;
      }
      
      .subtitle { 
        color: var(--text-muted); 
        margin-bottom: 3rem; 
        font-size: 1.1rem;
      }
      
      .status-card {
        background-color: var(--bg-surface);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1.5rem 2rem;
        margin-bottom: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
      }

      /* Subtle glow effect on card */
      .status-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
        opacity: 0;
        transition: opacity 0.3s ease;
      }

      .status-card:hover {
        border-color: #333333;
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
      }

      .status-card:hover::before {
        opacity: 1;
      }

      .server-info h2 {
        margin: 0 0 0.25rem 0;
        color: #ffffff;
        font-size: 1.1rem;
        font-weight: 600;
      }

      .server-info p {
        margin: 0;
        font-size: 0.85rem;
        color: var(--text-muted);
        font-family: 'JetBrains Mono', monospace;
      }

      .indicator {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-weight: bold;
        font-size: 0.9rem;
        font-family: 'JetBrains Mono', monospace;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .indicator svg {
        display: block;
      }
      
      .text-online { 
        color: #2ea043; 
        filter: drop-shadow(0 0 8px rgba(46, 160, 67, 0.4));
      }
      
      .text-offline { 
        color: #f85149; 
        filter: drop-shadow(0 0 8px rgba(248, 81, 73, 0.4));
      }
    </style>
  </head>
  <body>
    <a href="/" class="back-link">&larr; RETURN_TO_CORE</a>
    
    <h1>System Status</h1>
    <p class="subtitle">Live monitoring for the Osprey infrastructure.</p>

    <div class="status-card">
      <div class="server-info">
        <h2>TeamSpeak 5 Server</h2>
        <p>ts.theospreylibrary.com</p>
      </div>
      <div class="indicator" id="ts-status">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b949e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5V19A9 3 0 0 0 21 19V5"></path><path d="M3 12A9 3 0 0 0 21 12"></path></svg>
        <span style="color: #8b949e;">CHECKING...</span>
      </div>
    </div>

    <script>
      async function checkServerStatus() {
        const statusElement = document.getElementById('ts-status');
        if (!statusElement) return;

        const getIcon = (color: string) => `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5V19A9 3 0 0 0 21 19V5"></path><path d="M3 12A9 3 0 0 0 21 12"></path></svg>`;

        try {
          const response = await fetch('https://api.theospreylibrary.com/teamspeak');
          const data = await response.json();

          if (data.status === 'online') {
            statusElement.innerHTML = `
              <div class="indicator text-online">
                ${getIcon('#2ea043')}
                <span>OPERATIONAL</span>
              </div>`;
          } else {
            statusElement.innerHTML = `
              <div class="indicator text-offline">
                ${getIcon('#f85149')}
                <span>OFFLINE</span>
              </div>`;
          }
        } catch (error) {
          statusElement.innerHTML = `
            <div class="indicator text-offline">
              ${getIcon('#f85149')}
              <span>SYS_FAIL</span>
            </div>`;
        }
      }

      checkServerStatus();
      setInterval(checkServerStatus, 60000);
    </script>
  </body>
</html>