---
// src/pages/status.astro
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>System Status | Crescendo Engine</title>
    <style>
      body {
        font-family: system-ui, -apple-system, sans-serif;
        background-color: #0d1117;
        color: #c9d1d9;
        margin: 0 auto;
        padding: 4rem 2rem;
        max-width: 800px;
        line-height: 1.6;
      }
      h1 { color: #ffffff; font-size: 2.5rem; margin-bottom: 0.5rem; }
      .subtitle { color: #8b949e; margin-bottom: 3rem; }
      
      .status-card {
        background-color: #161b22;
        border: 1px solid #30363d;
        border-radius: 8px;
        padding: 1.5rem;
        margin-bottom: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .server-info h2 {
        margin: 0 0 0.25rem 0;
        color: #ffffff;
        font-size: 1.2rem;
      }

      .server-info p {
        margin: 0;
        font-size: 0.85rem;
        color: #8b949e;
      }

      .indicator {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: bold;
        font-size: 0.9rem;
      }

      .indicator svg {
        display: block;
      }
      
      .text-online { 
        color: #2ea043; 
        filter: drop-shadow(0 0 8px rgba(46, 160, 67, 0.4));
      }
      
      .text-offline { 
        color: #f85149; 
        filter: drop-shadow(0 0 8px rgba(248, 81, 73, 0.4));
      }
    </style>
  </head>
  <body>
    <a href="/" style="color: #58a6ff; text-decoration: none; font-weight: bold;">&larr; Back to Home</a>
    
    <h1>System Status</h1>
    <p class="subtitle">Live monitoring for the Crescendo Engine infrastructure.</p>

    <div class="status-card">
      <div class="server-info">
        <h2>TeamSpeak 5 Server</h2>
        <p>ts.theospreylibrary.com</p>
      </div>
      <div class="indicator" id="ts-status">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b949e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5V19A9 3 0 0 0 21 19V5"></path><path d="M3 12A9 3 0 0 0 21 12"></path></svg>
        <span style="color: #8b949e;">Checking...</span>
      </div>
    </div>

    <script>
      async function checkServerStatus() {
        const statusElement = document.getElementById('ts-status');
        if (!statusElement) return;

        // We dynamically inject the hex color directly into the stroke
        const getIcon = (color: string) => `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5V19A9 3 0 0 0 21 19V5"></path><path d="M3 12A9 3 0 0 0 21 12"></path></svg>`;

        try {
          const response = await fetch('https://api.theospreylibrary.com/teamspeak');
          const data = await response.json();

          if (data.status === 'online') {
            statusElement.innerHTML = `
              <div class="indicator text-online">
                ${getIcon('#2ea043')}
                <span>Operational</span>
              </div>`;
          } else {
            statusElement.innerHTML = `
              <div class="indicator text-offline">
                ${getIcon('#f85149')}
                <span>Offline</span>
              </div>`;
          }
        } catch (error) {
          statusElement.innerHTML = `
            <div class="indicator text-offline">
              ${getIcon('#f85149')}
              <span>Connection Failed</span>
            </div>`;
        }
      }

      checkServerStatus();
      setInterval(checkServerStatus, 60000);
    </script>
  </body>
</html>