---
// src/pages/devlog/index.astro
import { getCollection } from 'astro:content';

const allLogs = await getCollection('devlog');
// Sort by date, newest first
allLogs.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Devlog | Crescendo Engine</title>
    <style>
      body {
        font-family: system-ui, -apple-system, sans-serif;
        background-color: #0d1117;
        color: #c9d1d9;
        margin: 0 auto;
        padding: 4rem 2rem;
        max-width: 800px;
        line-height: 1.6;
      }
      h1 { color: #ffffff; font-size: 3rem; margin-bottom: 0.5rem; }
      .subtitle { color: #8b949e; font-size: 1.2rem; margin-bottom: 3rem; border-bottom: 1px solid #30363d; padding-bottom: 2rem; }
      a { color: #58a6ff; text-decoration: none; }
      a:hover { text-decoration: underline; }
      .back-btn { display: inline-block; margin-bottom: 2rem; font-weight: bold; }
      .post-list { list-style: none; padding: 0; }
      .post-item { background-color: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 1.5rem; margin-bottom: 1rem; }
      .post-item h2 { margin: 0 0 0.5rem 0; color: #ffffff; }
      .date { font-size: 0.85rem; color: #8b949e; }
    </style>
  </head>
  <body>
    <a href="/" class="back-btn">&larr; Back to Engine Overview</a>
    
    <h1>Development Log</h1>
    <p class="subtitle">Architecture decisions, rendering pipelines, and engineering notes.</p>

    <ul class="post-list">
      {allLogs.map((post) => (
        <li class="post-item">
          <a href={`/devlog/${post.id}`}>
            <h2>{post.data.title}</h2>
          </a>
          <span class="date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          <p>{post.data.description}</p>
        </li>
      ))}
    </ul>
  </body>
</html>